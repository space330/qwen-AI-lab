PORT=5173
QWEN_API_KEY=your_dashscope_api_key_here
QWEN_MODEL=qwen3.7-max
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_TIMEOUT_MS=60000
QWEN_SLOW_MODEL_TIMEOUT_MS=240000
QWEN_MAX_TOKENS=1200
QWEN_REPORT_MAX_TOKENS=3200
QWEN_SUMMARY_MAX_TOKENS=700
QWEN_FILE_CHAR_LIMIT=6000

# Agent (V2.0)
AGENT_MAX_ITERATIONS=5
AGENT_MAX_TOOL_STEPS=8
# web_search 检索服务商：qwen（复用 DashScope key 的千问内置联网搜索，默认，无需额外凭据）
#                        | bocha（博查真实检索，需下方 key）| mock（强制本地占位）
WEB_SEARCH_PROVIDER=qwen
# provider=qwen 时用于检索的模型（需支持 enable_search），默认 qwen-plus
QWEN_SEARCH_MODEL=qwen-plus
# provider=bocha 时使用的博查 Bocha key（仅后端读取；缺失则回退 Mock）
BOCHA_API_KEY=
BOCHA_BASE_URL=https://api.bochaai.com/v1
